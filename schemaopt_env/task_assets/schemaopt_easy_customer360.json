    {
      "query_id": "schemaopt_easy_customer360_vq_c01_01",
      "sql": "SELECT date_trunc('month', try_cast(b.\"updated_at\" AS TIMESTAMP)) AS metric_period, b.\"email\" AS email, COUNT(*) AS row_count, SUM(b.\"phone_extension\") AS sum_phone_extension FROM raw.marketo_leads b WHERE try_cast(b.\"updated_at\" AS TIMESTAMP) IS NOT NULL AND b.\"email\" IS NOT NULL GROUP BY metric_period, email",
      "normalized_sql": "select date_trunc('month', try_cast(b.\"updated_at\" as timestamp)) as metric_period, b.\"email\" as email, count(*) as row_count, sum(b.\"phone_extension\") as sum_phone_extension from raw.marketo_leads b where try_cast(b.\"updated_at\" as timestamp) is not null and b.\"email\" is not null group by metric_period, email",
